# Restreamer Configuration
RESTREAMER_API_AUTH_ENABLED=true
RESTREAMER_API_USERNAME=admin
RESTREAMER_API_PASSWORD=ChangeMe123!

# Ports
RESTREAMER_WEB_UI_PORT=8080
RESTREAMER_RTMP_PORT=1935
RESTREAMER_SRT_PORT=6000

# Performance
RESTREAMER_STREAM_QUALITY=source
RESTREAMER_MAX_MEMORY=2GB

# RTMPS Settings
RESTREAMER_OUTPUT_RTMPS=true
RESTREAMER_RTMPS_PORT=443

# SSL (Optional - for RTMPS ingest)
SSL_CERT_PATH=/ssl/cert.pem
SSL_KEY_PATH=/ssl/key.pem

# Logging
RESTREAMER_LOG_LEVEL=info
RESTREAMER_LOG_FORMAT=json

# Rate Limiting (prevent abuse)
RESTREAMER_RATE_LIMIT_REQUESTS=100
RESTREAMER_RATE_LIMIT_PERIOD=60